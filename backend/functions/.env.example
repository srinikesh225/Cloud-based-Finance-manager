# ExpenseCloud Cloud Functions - Environment Variables
# Copy this file to .env and fill in your actual values

# ========================================
# CLERK AUTHENTICATION
# ========================================
# Get this from: https://dashboard.clerk.com/last-active?path=api-keys
# Click "API Keys" → "Backend" → Copy Secret Key
CLERK_SECRET_KEY=sk_test_YOUR_CLERK_SECRET_KEY_HERE

# ========================================
# EMAIL CONFIGURATION - Gmail
# ========================================
# Gmail address to send emails from
EMAIL_USER=your-email@gmail.com

# Gmail App Password (NOT your regular password)
# Generate at: https://myaccount.google.com/apppasswords
# Select "Mail" and "Windows Computer" → copy password
EMAIL_PASSWORD=xxxx xxxx xxxx xxxx

# ========================================
# APPLICATION CONFIGURATION
# ========================================
# Your ExpenseCloud application URL
# Used in email links to redirect users back to your app
APP_URL=https://expensecloud.app

# Set to 'true' to use Clerk's native email system (requires additional setup)
# Set to 'false' to use nodemailer with Gmail/SendGrid
USE_CLERK_EMAIL=false

# ========================================
# OPTIONAL: SendGrid Configuration
# ========================================
# If you want to use SendGrid instead of Gmail, uncomment and fill:
# Get API key from: https://app.sendgrid.com/settings/api_keys
# SENDGRID_API_KEY=SG.YOUR_SENDGRID_API_KEY_HERE

# ========================================
# OPTIONAL: AWS SES Configuration
# ========================================
# If using AWS SES for email sending:
# AWS_REGION=us-east-1
# AWS_ACCESS_KEY_ID=your_access_key
# AWS_SECRET_ACCESS_KEY=your_secret_key
